# --- Pick ONE provider and set its key ---------------------------------
# Groq (default) — free tier, open-weight Llama model, get a key at
# https://console.groq.com/keys
GROQ_API_KEY=

# OpenAI — set ADITYA_MODEL=gpt-4o-mini
OPENAI_API_KEY=

# Anthropic — set ADITYA_MODEL=anthropic/claude-sonnet-4-5-20250929
ANTHROPIC_API_KEY=

# Google Gemini — set ADITYA_MODEL=gemini/gemini-2.0-flash
GEMINI_API_KEY=

# --- Agent config --------------------------------------------------------
ADITYA_MODEL=groq/llama-3.3-70b-versatile
ADITYA_NAME=Aditya
ADITYA_TEMPERATURE=0.7
ADITYA_MAX_TOKENS=2048
ADITYA_MAX_TOOL_ITERATIONS=6
# ADITYA_SYSTEM_PROMPT=Override the default system prompt here

# --- Server / security -----------------------------------------------
# Set this before deploying publicly; clients must send it as X-API-Key
ADITYA_API_KEY=
HOST=0.0.0.0
PORT=8000
